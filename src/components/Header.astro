---
---
<header class="header" id="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="Accueil Arqow">
      <img src="/assets/logo-dark.png" alt="Logo Arqow" />
      <span>Arqow</span>
    </a>
    <nav class="nav" id="site-nav" aria-label="Navigation principale">
      <a href="/#decouvrir">Découvrir</a>
      <a href="/#metiers">Métiers</a>
      <a href="/#fonctionnalites">Fonctionnalités</a>
      <a href="/#prix">Tarifs</a>
      <a href="/#essayer">Essayer</a>
    </nav>
    <div class="header-actions">
      <a class="pill dark" href="https://app.arqow.com/register">Essai gratuit</a>
      <button class="nav-toggle" id="nav-toggle" type="button" aria-expanded="false" aria-controls="site-nav" aria-label="Ouvrir le menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>
<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('site-nav');
  toggle?.addEventListener('click', () => {
    const open = header?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    toggle.setAttribute('aria-label', open ? 'Fermer le menu' : 'Ouvrir le menu');
  });
  nav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      header?.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Ouvrir le menu');
    });
  });
</script>
