---
import ContactAppLayout from "../../../layouts/ContactAppLayout.astro";
---

<ContactAppLayout title="Demande envoyée — Arqow" canonical="https://arqow.com/contact/merci/">
  <div class="contact-app">
    <aside class="contact-app-side">
      <a class="contact-brand" href="/">
        <img src="/assets/logo-dark.png" alt="Arqow" />
        <span>Arqow</span>
      </a>
      <p class="contact-side-label">Support</p>
    </aside>
    <main class="contact-app-main">
      <div class="contact-wizard contact-success">
        <span class="success-icon">✓</span>
        <h1>Demande envoyée</h1>
        <p class="wizard-lead">Votre ticket a bien été transmis à l’équipe Arqow. Nous revenons vers vous par email.</p>
        <div class="success-actions">
          <a class="btn primary" href="https://app.arqow.com/register">Essayer Arqow</a>
          <a class="text-link" href="/">Retour au site</a>
        </div>
      </div>
    </main>
  </div>
</ContactAppLayout>
