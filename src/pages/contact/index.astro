---
import ContactAppLayout from "../../layouts/ContactAppLayout.astro";
---

<ContactAppLayout
  title="Support Arqow"
  description="Accédez au portail support Arqow pour les clients. Prospects : démarrez votre essai gratuit."
  canonical="https://arqow.com/contact/"
>
  <div class="contact-app">
    <aside class="contact-app-side contact-app-side-min">
      <a class="contact-brand" href="/">
        <img src="/assets/logo-dark.png" alt="Arqow" />
        <span>Arqow</span>
      </a>
      <a class="contact-side-link" href="/">← Retour au site</a>
    </aside>

    <main class="contact-app-main">
      <div class="contact-wizard contact-hub">
        <p class="kicker">Support</p>
        <h1>Besoin d’aide ?</h1>
        <p class="wizard-lead">
          Les demandes clients passent par le portail support — pas par email.
        </p>

        <article class="contact-hub-card">
          <h2>Déjà client Arqow</h2>
          <p>Ouvrez une demande, consultez vos tickets et retrouvez l’aide produit.</p>
          <a class="btn primary" href="https://help.arqow.com/" target="_blank" rel="noopener">Accéder au portail support</a>
        </article>

        <article class="contact-hub-card muted">
          <h2>Pas encore client</h2>
          <p>Testez Arqow gratuitement pendant un mois, sans carte bancaire.</p>
          <a class="btn secondary" href="https://app.arqow.com/register">Commencer l’essai gratuit</a>
        </article>
      </div>
    </main>
  </div>
</ContactAppLayout>
