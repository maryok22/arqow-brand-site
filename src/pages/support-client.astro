---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---
<BaseLayout
  title="Support client pour régies et architectes — Arqow"
  description="Transformez les demandes clients en tickets structurés avec Arqow. Support relié aux dossiers pour régies immobilières et bureaux d’architecture en Suisse."
  canonical="https://arqow.com/support-client/"
>
  <Header />
  <main>
    <section class="section">
      <div class="container" style="max-width:940px">
        <p class="kicker">Support</p>
        <h1 class="page-title">Support client structuré</h1>
        <p class="lead">Chaque demande devient un ticket suivi, catégorisé et relié au bon dossier — pour vos équipes comme pour vos clients.</p>
        <div class="hero-actions">
          <a class="btn primary" href="https://app.arqow.com/register">Essayer gratuitement</a>
          <a class="btn secondary" href="/#support">Voir l’aperçu interactif</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
