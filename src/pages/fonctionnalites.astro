---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---
<BaseLayout
  title="Fonctionnalités Arqow — Dossiers, documents, validations, support"
  description="Découvrez les fonctionnalités Arqow : espace client, documents versionnés, validations traçables, support structuré et export ZIP pour professionnels de l’immobilier en Suisse."
  canonical="https://arqow.com/fonctionnalites/"
>
  <Header />
  <main>
    <section class="section">
      <div class="container" style="max-width:940px">
        <p class="kicker">Fonctionnalités</p>
        <h1 class="page-title">Fonctionnalités du portail client Arqow</h1>
        <p class="lead">Dossiers, documents, validations, messages et support client — centralisés dans un espace clair pour vos clients et votre équipe.</p>
        <div class="hero-actions">
          <a class="btn primary" href="https://app.arqow.com/register">Essayer gratuitement</a>
          <a class="btn secondary" href="/#fonctionnalites">Voir sur la page d’accueil</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
