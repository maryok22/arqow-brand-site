---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { homeFaq } from "../data/faq.ts";
---

<BaseLayout
  title="Arqow — Portail client suisse pour régies, architectes et immobilier"
  description="Arqow centralise dossiers, documents, validations et échanges clients pour régies, architectes, courtiers et PPE en Suisse. Premier mois gratuit, sans carte bancaire."
  canonical="https://arqow.com/"
  faqItems={homeFaq}
>
  <Header />
  <main>
    <section class="hero container">
      <div class="hero-copy">
        <h1>Le portail client de vos dossiers.</h1>
        <p class="hero-lead">Documents, validations et messages — un seul espace clair pour vos clients.</p>
        <div class="hero-actions">
          <a class="btn primary" href="https://app.arqow.com/register">Commencer gratuitement</a>
          <a class="btn secondary" href="#decouvrir">Découvrir</a>
        </div>
      </div>

      <div class="product-preview" aria-label="Aperçu de Arqow">
        <div class="dashboard hero-dashboard">
          <div class="browser"><i></i><i></i><i></i><span>regiedupont.app.arqow.com</span></div>
          <div class="app-preview">
            <aside class="app-side">
              <div class="tenant-dot">RD</div>
              <strong>Régie Dupont</strong>
              <a class="active">Dossiers</a>
              <a>Documents</a>
              <a>Support</a>
            </aside>
            <section class="app-main">
              <div class="app-head">
                <div>
                  <span class="label">Client</span>
                  <h3>Mandat de gestion 2026</h3>
                </div>
                <span class="status">À valider</span>
              </div>
              <div class="task-card">
                <div>
                  <span class="label">DOS-000231</span>
                  <h4>Avenant au mandat</h4>
                  <p>2 documents · 1 question</p>
                </div>
                <button>Ouvrir</button>
              </div>
              <div class="timeline hero-timeline">
                <div class="timeline-item"><time>09:13</time><p>Document envoyé au client.</p><small>Envoyé</small></div>
                <div class="timeline-item"><time>09:16</time><p>Document consulté.</p><small>Lu</small></div>
                <div class="timeline-item"><time>09:31</time><p>Pièce validée.</p><small>Validé</small></div>
              </div>
            </section>
          </div>
        </div>
      </div>
    </section>

    <section class="section" id="decouvrir" data-reveal>
      <div class="container">
        <p class="kicker">Le problème</p>
        <h2 class="section-title">Trop d’échanges. Pas assez de clarté.</h2>
        <p class="section-lead">Emails, appels, PDF renvoyés : vos équipes perdent du temps à retrouver l’information au lieu de faire avancer les dossiers.</p>
        <div class="clean-list">
          <div class="clean-item"><span>1</span><div><h3>Les documents se dispersent</h3><p>Contrats, plans et avenants finissent dans des fils impossibles à suivre.</p></div></div>
          <div class="clean-item"><span>2</span><div><h3>Les validations manquent de trace</h3><p>Chaque décision importante doit pouvoir être retrouvée, comprise et datée.</p></div></div>
          <div class="clean-item"><span>3</span><div><h3>L’expérience client ne reflète pas votre niveau</h3><p>Votre travail est sérieux. L’espace donné à vos clients doit l’être aussi.</p></div></div>
        </div>
      </div>
    </section>

    <section class="section dark" id="metiers" data-reveal>
      <div class="container">
        <p class="kicker">Pour qui</p>
        <h2 class="section-title">Pensé pour les métiers où chaque document compte.</h2>
        <div class="profession-grid">
          <a class="profession-block" href="/regie-immobiliere/"><span class="symbol">⌂</span><h3>Régies immobilières</h3><p>Mandats, propriétaires, locataires et demandes.</p></a>
          <a class="profession-block" href="/architecte/"><span class="symbol">⌁</span><h3>Architectes</h3><p>Plans, versions, choix clients et décisions projet.</p></a>
          <a class="profession-block" href="/courtier-immobilier/"><span class="symbol">◇</span><h3>Courtiers</h3><p>Dossiers vendeurs, pièces acheteurs et suivi.</p></a>
          <a class="profession-block" href="/administrateur-ppe/"><span class="symbol">◫</span><h3>Administrateurs PPE</h3><p>Communications, procès-verbaux et demandes.</p></a>
        </div>
      </div>
    </section>

    <section class="section" id="fonctionnalites" data-reveal>
      <div class="container">
        <p class="kicker">Fonctionnalités</p>
        <h2 class="section-title">Moins de bruit. Plus de maîtrise.</h2>
        <div class="benefit-grid">
          <article class="benefit wide">
            <div class="benefit-visual visual-portal" aria-hidden="true">
              <div class="v-sidebar"><i></i><i></i><i class="on"></i></div>
              <div class="v-main"><span></span><span></span><span class="long"></span></div>
            </div>
            <h3>Chaque client dispose de son espace.</h3>
            <p>Dossiers, documents, messages et statuts regroupés dans un portail clair, à votre image.</p>
          </article>
          <article class="benefit">
            <div class="benefit-visual visual-versions" aria-hidden="true">
              <div class="v-doc d1"></div>
              <div class="v-doc d2"></div>
              <div class="v-doc d3"><small>v3</small></div>
            </div>
            <h3>Documents versionnés</h3>
            <p>Une nouvelle version ne remplace pas l’ancienne. L’historique reste lisible.</p>
          </article>
          <article class="benefit">
            <div class="benefit-visual visual-valid" aria-hidden="true">
              <div class="v-check">✓</div>
              <div class="v-lines"><i></i><i></i><i class="done"></i></div>
            </div>
            <h3>Validations traçables</h3>
            <p>Vous savez qui a consulté, commenté ou validé une pièce.</p>
          </article>
          <article class="benefit">
            <div class="benefit-visual visual-ticket" aria-hidden="true">
              <div class="v-ticket"><span>SUP-0042</span><em>En attente</em></div>
            </div>
            <h3>Demandes suivies</h3>
            <p>Support et questions arrivent au bon endroit, avec un statut clair.</p>
          </article>
          <article class="benefit">
            <div class="benefit-visual visual-brand" aria-hidden="true">
              <div class="v-brand-dot"></div>
              <div class="v-brand-bar"></div>
            </div>
            <h3>Portail à votre image</h3>
            <p>Logo et couleurs de votre structure pour un espace client cohérent avec votre identité.</p>
          </article>
          <article class="benefit">
            <div class="benefit-visual visual-export" aria-hidden="true">
              <div class="v-zip">ZIP</div>
              <div class="v-files"><i></i><i></i><i></i></div>
            </div>
            <h3>Export et archivage</h3>
            <p>Récupérez un dossier complet : documents, messages et journal d’activité. Vos données restent maîtrisées.</p>
          </article>
        </div>
        <p class="benefits-more">
          Et bien plus encore…
          <a href="/audit/">Évaluez la maturité de votre relation client</a>
        </p>
      </div>
    </section>

    <section class="section dark" id="support" data-reveal>
      <div class="container">
        <p class="kicker">Support client</p>
        <h2 class="section-title">Les demandes clients, structurées comme il faut.</h2>
        <p class="section-lead">Chaque demande devient un ticket : catégorisé, suivi et relié au bon dossier.</p>
        <div class="ticket-preview" id="ticket-demo">
          <aside class="ticket-sidebar">
            <h3>Demandes récentes</h3>
            <button class="ticket-row active" type="button" data-ticket="0" aria-pressed="true">
              <span class="avatar">JM</span>
              <div><strong>Question sur l’avenant</strong><small>En attente · Jeanne Martin</small></div>
            </button>
            <button class="ticket-row" type="button" data-ticket="1" aria-pressed="false">
              <span class="avatar">AP</span>
              <div><strong>Plan version B</strong><small>Ouvert · Atelier Pierre</small></div>
            </button>
            <button class="ticket-row" type="button" data-ticket="2" aria-pressed="false">
              <span class="avatar">RB</span>
              <div><strong>Accès propriétaire</strong><small>Résolu · Régie Blanc</small></div>
            </button>
          </aside>
          <section class="ticket-panel" id="ticket-panel" aria-live="polite">
            <div class="ticket-top">
              <div>
                <span class="label" id="ticket-id">Ticket SUP-0042</span>
                <h3 id="ticket-title">Question sur l’avenant au mandat</h3>
              </div>
              <span class="status" id="ticket-status">À traiter</span>
            </div>
            <div id="ticket-messages">
              <div class="message client"><strong>Jeanne Martin</strong><p>Pouvez-vous confirmer que la version publiée est bien la dernière avant validation ?</p></div>
              <div class="message"><strong>Régie Dupont</strong><p>Oui, c’est la version finale. Vous pouvez la valider depuis votre espace.</p></div>
            </div>
          </section>
        </div>
      </div>
    </section>

    <section class="section setup-section" data-reveal>
      <div class="container">
        <p class="kicker">Démarrage</p>
        <h2 class="section-title">En ligne en quelques minutes.</h2>
        <p class="section-lead">Pas d’appel obligatoire, pas de configuration longue. Vous créez votre compte et c’est parti.</p>
        <div class="steps-grid">
          <article class="step-card">
            <span class="step-num">1</span>
            <h3>Créez votre compte</h3>
            <p>Inscription gratuite, sans carte bancaire. Votre portail est prêt immédiatement.</p>
          </article>
          <article class="step-card">
            <span class="step-num">2</span>
            <h3>Invitez vos clients</h3>
            <p>Ajoutez vos premiers clients et ouvrez leurs dossiers en quelques clics.</p>
          </article>
          <article class="step-card">
            <span class="step-num">3</span>
            <h3>Publiez vos documents</h3>
            <p>Déposez vos pièces, vos clients les consultent et valident depuis leur espace.</p>
          </article>
        </div>
        <div class="setup-cta">
          <a class="btn primary" href="https://app.arqow.com/register">Créer mon compte gratuitement</a>
        </div>
      </div>
    </section>

    <section class="section pricing-section" id="prix" data-reveal>
      <div class="container">
        <p class="kicker">Tarifs</p>
        <h2 class="section-title">Des offres simples et prévisibles.</h2>

        <div class="pricing-grid">
          <article class="price-card">
            <h3>Essentiel</h3>
            <p class="desc">Pour indépendants et petites structures.</p>
            <div class="price-block">
              <div class="price-free">0 CHF <small>le 1<sup>er</sup> mois</small></div>
              <div class="price-then">puis CHF 59 / mois</div>
            </div>
            <a class="btn price-cta" href="https://app.arqow.com/register">Essayer gratuitement</a>
            <p class="price-footnote">Sans engagement · Sans carte bancaire</p>
            <ul><li>1 utilisateur interne</li><li>Jusqu’à 50 clients</li><li>Dossiers illimités</li><li>Documents & messages</li><li>20 Go inclus</li><li>Export ZIP par dossier</li></ul>
          </article>
          <article class="price-card featured">
            <span class="flag">Recommandé</span>
            <h3>Pro</h3>
            <p class="desc">Pour les équipes qui centralisent leurs échanges clients.</p>
            <div class="price-block">
              <div class="price-free">0 CHF <small>le 1<sup>er</sup> mois</small></div>
              <div class="price-then">puis CHF 119 / mois</div>
            </div>
            <a class="btn price-cta featured-cta" href="https://app.arqow.com/register">Essayer gratuitement</a>
            <p class="price-footnote">Sans engagement · Sans carte bancaire</p>
            <ul><li>Utilisateurs illimités</li><li>Clients illimités</li><li>Branding logo + couleur</li><li>Support client & actualités</li><li>100 Go inclus</li><li>Export complet</li><li>Notifications email</li></ul>
          </article>
          <article class="price-card">
            <span class="flag soon">Bientôt</span>
            <h3>Business</h3>
            <p class="desc">Expérience totalement à votre image.</p>
            <div class="price-block">
              <div class="price-free solo">Sur mesure</div>
              <div class="price-then">Devis personnalisé</div>
            </div>
            <a class="btn price-cta" href="https://app.arqow.com/register">Essayer gratuitement</a>
            <p class="price-footnote">Ou <a href="/contact/" class="text-link-discreet">demande sur mesure</a></p>
            <ul><li>Domaine personnalisé</li><li>Branding avancé</li><li>500 Go inclus</li><li>Support prioritaire</li><li>Accompagnement configuration</li></ul>
          </article>
        </div>
      </div>
    </section>

    <section class="section trust-section" data-reveal>
      <div class="container">
        <p class="kicker">Confiance</p>
        <h2 class="section-title">Vos données. Votre contrôle.</h2>
        <div class="trust-grid">
          <article class="trust-card">
            <span class="trust-icon">CH</span>
            <h3>Produit suisse</h3>
            <p>Conçu et opéré par <a href="https://evoswiss.ch" target="_blank" rel="noopener">EvoSwiss</a>, pour les professionnels suisses.</p>
            <p class="trust-note">Compatible dans tous les pays francophones.</p>
          </article>
          <article class="trust-card">
            <span class="trust-icon">⛨</span>
            <h3>Données maîtrisées</h3>
            <p>Espaces sécurisés, accès contrôlés. Vos documents et échanges clients restent dans un environnement professionnel.</p>
          </article>
          <article class="trust-card">
            <span class="trust-icon">↓</span>
            <h3>Export à tout moment</h3>
            <p>ZIP complet par dossier ou par client : documents, messages et historique. Vous restez propriétaire de vos données.</p>
          </article>
          <article class="trust-card">
            <span class="trust-icon">§</span>
            <h3>Pensé pour la nLPD</h3>
            <p>Traçabilité, export et contrôle des accès — les bases pour gérer des données clients en Suisse.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section product-proof" data-reveal>
      <div class="container product-proof-layout">
        <div>
          <p class="kicker">Le produit</p>
          <h2 class="section-title">Voyez-le par vous-même.</h2>
          <p class="section-lead">Pas de démo vidéo interminable. Créez votre compte et explorez l’interface réelle en 2 minutes — gratuitement, sans carte bancaire.</p>
          <ul class="proof-list">
            <li>Interface complète dès l’inscription</li>
            <li>Accompagnement direct au lancement</li>
            <li>Aucun engagement les 30 premiers jours</li>
          </ul>
          <a class="btn primary" href="https://app.arqow.com/register">Essayer l’interface maintenant</a>
        </div>
        <div class="product-preview proof-preview" aria-hidden="true">
          <div class="dashboard">
            <div class="browser"><i></i><i></i><i></i><span>votreregie.app.arqow.com</span></div>
            <div class="app-preview">
              <aside class="app-side">
                <div class="tenant-dot">VR</div>
                <strong>Votre régie</strong>
                <a class="active">Dossiers</a>
                <a>Documents</a>
                <a>Clients</a>
              </aside>
              <section class="app-main">
                <div class="app-head">
                  <div>
                    <span class="label">Votre espace</span>
                    <h3>Prêt à l’emploi</h3>
                  </div>
                  <span class="status">Actif</span>
                </div>
                <div class="task-card">
                  <div>
                    <span class="label">DOS-000001</span>
                    <h4>Premier dossier client</h4>
                    <p>Créé en 2 minutes</p>
                  </div>
                  <button>Ouvrir</button>
                </div>
              </section>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section essayer-section" id="essayer" data-reveal>
      <div class="container essayer-inner">
        <p class="kicker">Essayer</p>
        <h2 class="section-title">Le meilleur moyen de comprendre, c’est d’essayer.</h2>
        <p class="section-lead">
          Créez votre compte gratuitement et explorez Arqow directement.
          Si une question surgit pendant votre essai, notre équipe est là.
        </p>
        <a class="btn primary" href="https://app.arqow.com/register">Commencer gratuitement</a>
        <p class="essayer-note">
          0 CHF le premier mois · Sans carte bancaire ·
          <a href="/contact/" class="text-link-discreet">Une question ?</a>
        </p>
      </div>
    </section>

    <section class="section faq" data-reveal>
      <div class="container">
        <p class="kicker">FAQ</p>
        <h2 class="section-title">Clair avant de commencer.</h2>
        <details open>
          <summary>{homeFaq[0].question}</summary>
          <p>{homeFaq[0].answer}</p>
        </details>
        <details>
          <summary>{homeFaq[1].question}</summary>
          <p>{homeFaq[1].answer}</p>
        </details>
        <details>
          <summary>{homeFaq[2].question}</summary>
          <p>{homeFaq[2].answer}</p>
        </details>
        <details>
          <summary>{homeFaq[3].question}</summary>
          <p>{homeFaq[3].answer}</p>
        </details>
        <details>
          <summary>{homeFaq[4].question}</summary>
          <p>{homeFaq[4].answer}</p>
        </details>
      </div>
    </section>

    <section class="section final-cta" data-reveal>
      <div class="container final-cta-inner">
        <div>
          <h2 class="section-title">Prêt à essayer ?</h2>
          <p>0 CHF le premier mois · Sans carte bancaire · En ligne en quelques minutes</p>
        </div>
        <div class="final-cta-actions">
          <a class="btn primary" href="https://app.arqow.com/register">Commencer gratuitement</a>
        </div>
        <p class="final-cta-discreet">
          <a href="/contact/" class="text-link-discreet">Une question pendant votre essai ?</a>
        </p>
      </div>
    </section>

    <script>
      const revealItems = document.querySelectorAll('[data-reveal]');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) entry.target.classList.add('is-visible');
        });
      }, { threshold: 0.12 });
      revealItems.forEach((item) => observer.observe(item));

      const tickets = [
        {
          id: 'Ticket SUP-0042',
          title: 'Question sur l’avenant au mandat',
          status: 'À traiter',
          messages: [
            { client: true, author: 'Jeanne Martin', text: 'Pouvez-vous confirmer que la version publiée est bien la dernière avant validation ?' },
            { client: false, author: 'Régie Dupont', text: 'Oui, c’est la version finale. Vous pouvez la valider depuis votre espace.' }
          ]
        },
        {
          id: 'Ticket SUP-0038',
          title: 'Validation du plan version B',
          status: 'Ouvert',
          messages: [
            { client: true, author: 'Atelier Pierre', text: 'Nous avons publié la version B du plan rez-de-chaussée. Pouvez-vous valider avant la réunion de chantier ?' },
            { client: false, author: 'Bureau architecture', text: 'Bien reçu. Nous consultons et revenons vers vous avec nos remarques dans le dossier.' }
          ]
        },
        {
          id: 'Ticket SUP-0029',
          title: 'Accès propriétaire',
          status: 'Résolu',
          messages: [
            { client: true, author: 'Régie Blanc', text: 'Le propriétaire M. Keller n’arrive pas à accéder à son espace client.' },
            { client: false, author: 'Support Arqow', text: 'Accès réinitialisé et lien renvoyé. Le propriétaire s’est connecté avec succès.' }
          ]
        }
      ];

      const ticketRows = document.querySelectorAll('#ticket-demo .ticket-row');
      const ticketPanel = document.getElementById('ticket-panel');
      const ticketId = document.getElementById('ticket-id');
      const ticketTitle = document.getElementById('ticket-title');
      const ticketStatus = document.getElementById('ticket-status');
      const ticketMessages = document.getElementById('ticket-messages');

      function renderTicket(index) {
        const ticket = tickets[index];
        if (!ticket || !ticketPanel) return;

        ticketPanel.classList.add('is-switching');
        window.setTimeout(() => {
          ticketId.textContent = ticket.id;
          ticketTitle.textContent = ticket.title;
          ticketStatus.textContent = ticket.status;
          ticketMessages.innerHTML = ticket.messages.map((msg) => `
            <div class="message${msg.client ? ' client' : ''}">
              <strong>${msg.author}</strong>
              <p>${msg.text}</p>
            </div>
          `).join('');
          ticketPanel.classList.remove('is-switching');
        }, 160);

        ticketRows.forEach((row, i) => {
          const active = i === index;
          row.classList.toggle('active', active);
          row.setAttribute('aria-pressed', active ? 'true' : 'false');
        });
      }

      ticketRows.forEach((row) => {
        row.addEventListener('click', () => {
          renderTicket(Number(row.dataset.ticket));
        });
      });
    </script>
  </main>
  <Footer />
</BaseLayout>
